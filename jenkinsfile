pipeline {
    agent any

    environment {
        DEPLOY_DIR = "/var/www/html"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Building Car Website...'
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    sudo rm -rf ${DEPLOY_DIR}/*
                    sudo cp -r * ${DEPLOY_DIR}/
                """
            }
        }
    }

    post {
        success {
            echo 'Car Website deployed successfully!'
        }

        failure {
            echo 'Deployment failed!'
        }
    }
}
